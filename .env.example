# Bolão da Copa — variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha os valores antes de subir o servidor

# Banco de dados PostgreSQL (obrigatório)
DATABASE_URL=postgresql://user:password@localhost:5432/bolao

# Segredo para assinar os tokens JWT (obrigatório — use uma string longa e aleatória)
SESSION_SECRET=troque-por-uma-string-secreta-longa

# API de futebol — football-data.org (necessário para importar jogos da Copa)
# Crie uma conta gratuita em: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=sua_chave_aqui

# Conta admin padrão criada automaticamente na primeira inicialização (opcional)
# Se não definido, usa os valores abaixo:
#   email: admin@bolao.com
#   senha: admin123
ADMIN_EMAIL=admin@bolao.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador
